# ── API Keys ────────────────────────────────────────────────────────────────
# Birdeye API key (required) — get a free key at https://birdeye.so/
BIRDEYE_API_KEY=your_birdeye_api_key_here

# Helius API key (recommended) — enables history depth & consistency analysis
# Get a free key (1M credits/month) at https://dev.helius.xyz/
# If not set, the tool will still work using Birdeye data only.
HELIUS_API_KEY=your_helius_api_key_here

# ── Filter Thresholds ────────────────────────────────────────────────────────
# Minimum number of trades a wallet must have (Birdeye-reported)
MIN_TRADES=30

# Minimum win rate 0.0–1.0 (0.55 = 55%)
MIN_WIN_RATE=0.55

# Minimum days of trading history (requires HELIUS_API_KEY)
MIN_HISTORY_DAYS=30

# Must have traded within this many days (0 = disable recency gate)
MAX_ACTIVE_AGO_DAYS=7

# Minimum profit factor (total gains / total losses). 1.0 = break even, 1.5 = 50% more gains than losses
MIN_PROFIT_FACTOR=1.2

# ── Discovery ────────────────────────────────────────────────────────────────
# How many wallets to pull from each Birdeye leaderboard (max 200)
DISCOVERY_BATCH=200

# Max SWAP transactions to fetch per wallet from Helius (more = deeper history, slower)
HELIUS_TX_LIMIT=500

# ── Output ───────────────────────────────────────────────────────────────────
# Number of top wallets to display and save
TOP_N=20

# Output file for ranked wallet results
OUTPUT_FILE=top_wallets.json

# Set to "true" to also add found wallets to the copy-trading bot's tracked_wallets.json
EXPORT_FOR_BOT=false

# Path to bot's tracked_wallets.json (only used if EXPORT_FOR_BOT=true)
BOT_WALLETS_FILE=../solana-trading-bot/tracked_wallets.json
