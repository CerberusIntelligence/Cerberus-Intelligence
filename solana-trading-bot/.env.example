# ===========================================
# SOLANA ALPHA BOT v2 — CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values
# NEVER share your .env file or commit it to git!
# Strategy: Monitor Telegram alpha channels → validate on-chain → auto-trade

# -------------------------------------------
# TRADING MODE
# -------------------------------------------
# Set to true for paper trading (no real trades)
# Set to false for live trading (real money!)
# ALWAYS start with paper trading to test your strategy!
PAPER_TRADING=true

# -------------------------------------------
# TELEGRAM SETTINGS (Required)
# -------------------------------------------
# Get these from https://my.telegram.org/apps (for channel monitoring)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token

# Your Telegram chat ID (for receiving notifications)
# Get it by messaging @userinfobot
TELEGRAM_CHAT_ID=your_chat_id

# Channels to monitor (comma-separated usernames without @)
# Example: channel1,channel2,channel3
MONITORED_CHANNELS=

# -------------------------------------------
# SOLANA SETTINGS (Required)
# -------------------------------------------
# Your wallet private key (base58 encoded)
# WARNING: Keep this secure! Never share!
SOLANA_PRIVATE_KEY=your_private_key_base58

# RPC endpoints (use paid RPC for better performance)
# Free: https://api.mainnet-beta.solana.com
# Paid options: Helius, QuickNode, Alchemy, Triton
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# -------------------------------------------
# TRADING SETTINGS
# -------------------------------------------
# Starting portfolio size in SOL (auto-detected if not set)
PORTFOLIO_SIZE_SOL=3.5

# Risk per trade as decimal (0.02 = 2%)
RISK_PER_TRADE=0.02

# Maximum SOL per single trade
MAX_POSITION_SOL=0.1

# Minimum liquidity in USD to consider a token
MIN_LIQUIDITY_USD=10000

# Slippage tolerance in basis points (500 = 5%)
SLIPPAGE_BPS=500

# Priority fee in lamports for faster execution
# Higher = faster but more expensive
# Recommended: 100000-500000 for sniper mode
PRIORITY_FEE_LAMPORTS=100000

# -------------------------------------------
# SAFETY THRESHOLDS
# -------------------------------------------
# Minimum % of liquidity that must be locked
MIN_LP_LOCKED_PERCENT=80

# Maximum % a single holder can own
MAX_TOP_HOLDER_PERCENT=10

# Maximum % dev/insider wallets can hold
MAX_DEV_WALLET_PERCENT=5

# Minimum number of token holders
MIN_HOLDER_COUNT=100

# Reject tokens with these authorities (true/false)
REJECT_MINT_AUTHORITY=true
REJECT_FREEZE_AUTHORITY=true

# -------------------------------------------
# EXIT STRATEGY
# -------------------------------------------
# Take profit levels (multipliers, e.g., 2.0 = 2x = 100% gain)
TAKE_PROFIT_LEVELS=2.0,5.0,10.0

# Percentage to sell at each TP level (must sum to 1.0)
TAKE_PROFIT_PERCENTS=0.3,0.3,0.4

# Stop loss as decimal (0.5 = sell if down 50%)
STOP_LOSS_PERCENT=0.5

# Trailing stop as decimal (0.2 = 20% from highest)
TRAILING_STOP_PERCENT=0.2

# Exit position if no pump after X minutes
TIMEOUT_MINUTES=30

# -------------------------------------------
# WALLET TRACKING (Copy Trading)
# -------------------------------------------
# Enable wallet tracking
WALLET_TRACKING_ENABLED=true

# Wallets to copy trade (comma-separated addresses)
# Add addresses of successful traders you want to follow
TRACKED_WALLETS=

# -------------------------------------------
# TWITTER/SOCIAL MONITORING (Optional)
# -------------------------------------------
# Enable Twitter sentiment analysis
TWITTER_ENABLED=false

# Twitter API Bearer Token (from developer.twitter.com)
TWITTER_BEARER_TOKEN=

# Additional keywords to track (comma-separated)
TWITTER_KEYWORDS=

# -------------------------------------------
# RATE LIMITING
# -------------------------------------------
# Maximum trades per hour
MAX_TRADES_PER_HOUR=10

# Cooldown between trades in seconds
COOLDOWN_SECONDS=30
